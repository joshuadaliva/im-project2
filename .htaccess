Options -Indexes
ServerSignature Off

<IfModule mod_headers.c>
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "same-origin"
</IfModule>

<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag session.cookie_httponly On
    php_value session.cookie_samesite Strict
    php_flag session.use_strict_mode On
</IfModule>
